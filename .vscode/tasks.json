		{
			"label": "diagnose-5174",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$ErrorActionPreference='Continue';\n'== Test-NetConnection ==';\ntry { Test-NetConnection -ComputerName 'localhost' -Port 5174 | Select-Object ComputerName,RemotePort,TcpTestSucceeded | Format-Table -AutoSize | Out-String } catch { $_.Exception.Message };\ntry { Test-NetConnection -ComputerName '127.0.0.1' -Port 5174 | Select-Object ComputerName,RemotePort,TcpTestSucceeded | Format-Table -AutoSize | Out-String } catch { $_.Exception.Message };\ntry { Test-NetConnection -ComputerName '::1' -Port 5174 | Select-Object ComputerName,RemotePort,TcpTestSucceeded | Format-Table -AutoSize | Out-String } catch { $_.Exception.Message };\n'== HTTP ==';\nforeach ($u in @('http://localhost:5174/','http://127.0.0.1:5174/','http://[::1]:5174/')) {\n  try {\n    $r = Invoke-WebRequest -Uri $u -UseBasicParsing -TimeoutSec 3;\n    \"$u -> $($r.StatusCode)\";\n  } catch {\n    \"$u -> ERR: $($_.Exception.Message)\";\n  }\n}\n"
			],
			"isBackground": false
		},
